# Copy to `.env` and adjust for your environment.

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (SQLite default for local dev)
DATABASE_URL=sqlite:///./brain_cognitive.db

# Docker / Postgres example:
# DATABASE_URL=postgresql+psycopg2://brain:brain@localhost:5432/brain

# Cognitive parameters
EMERGENCY_DISTANCE_THRESHOLD=0.35
ETHICS_MAX_SPEED=1.0
SYNAPSE_LEARNING_RATE=0.05
SYNAPSE_ELIGIBILITY_DECAY=0.9
SYNAPSE_WEIGHT_CLIP=2.0
MEMORY_WORKING_CAPACITY=64
MEMORY_EPISODIC_MAX=10000

# Persistence
PERSIST_EVENTS=true
